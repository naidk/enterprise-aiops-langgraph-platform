# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Enterprise AIOps Platform"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# ── API Server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*                   # comma-separated list in production

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set LLM_PROVIDER=mock for demo mode (no API key required).
# Set to "anthropic" or "openai" for real LLM-powered agents.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text                  # text (dev) | json (prod/Docker)
LOG_DIR=logs

# ── Storage ────────────────────────────────────────────────────────────────────
STORAGE_DIR=storage
INCIDENTS_FILE=storage/incidents.json
AUDIT_LOG_FILE=storage/audit_log.json
METRICS_FILE=storage/metrics.json

# ── AIOps Behaviour ────────────────────────────────────────────────────────────
AUTO_REMEDIATION=false           # true = skip approval gates
ESCALATION_THRESHOLD=3           # open incidents before PagerDuty fire
MAX_REMEDIATION_RETRIES=3        # max retry loops before escalation
INCIDENT_TTL_DAYS=90

# ── Pipeline Simulator ─────────────────────────────────────────────────────────
SIMULATOR_TICK_SECONDS=10        # how often to emit a random event
SIMULATOR_FAILURE_RATE=0.15      # 0.0–1.0 probability per tick

# ── Jira Integration ──────────────────────────────────────────────────────────
# Leave JIRA_ENABLED=false for mock mode (stub tickets only)
JIRA_ENABLED=false
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
JIRA_PROJECT_KEY=AIOPS
JIRA_USER_EMAIL=aiops-bot@your-org.com
